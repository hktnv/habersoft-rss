{
  "name": "rss-admin-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Foundation-only admin UI shell for the Habersoft RSS product family.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/verify-build.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:auth-session-sentinel": "node scripts/auth-session-sentinel-harness.mjs",
    "test:proxy-security": "node scripts/proxy-security-harness.mjs",
    "test:fullstack": "node scripts/root-fullstack-acceptance.mjs",
    "verify:production-readiness": "node scripts/production-readiness-verify.mjs",
    "verify:auth-boundary": "node scripts/auth-boundary-verify.mjs"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
