{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rss.habersoft.com/schemas/main-service/staging-host-requirements.schema.json",
  "title": "main-service staging host requirements",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "environment",
    "application",
    "application_version",
    "master_release",
    "master_hash",
    "master_count",
    "required_platform",
    "operating_system",
    "docker_engine_required",
    "docker_compose_v2_required",
    "noninteractive_docker_access_required",
    "ssh_batch_mode_required",
    "pinned_known_hosts_required",
    "remote_marker_required",
    "remote_marker_value",
    "production_compose_service_count",
    "compose_services",
    "api_binding",
    "api_host_port",
    "public_database_port_allowed",
    "public_redis_port_allowed",
    "public_worker_port_allowed",
    "persistent_postgresql_volume_required",
    "persistent_redis_volume_required",
    "off_host_postgresql_backup_required_before_rollout",
    "resource_limits",
    "capacity_model",
    "filesystem",
    "edge_conditions",
    "remote_preflight_required",
    "remote_deployment_performed"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "environment": { "const": "staging" },
    "application": { "const": "main-service" },
    "application_version": { "const": "0.1.0-ms-017" },
    "master_release": { "const": "rss-habersoft-master-v12" },
    "master_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "master_count": { "const": 29 },
    "required_platform": { "const": "linux/amd64" },
    "operating_system": { "const": "Linux" },
    "docker_engine_required": { "const": true },
    "docker_compose_v2_required": { "const": true },
    "noninteractive_docker_access_required": { "const": true },
    "ssh_batch_mode_required": { "const": true },
    "pinned_known_hosts_required": { "const": true },
    "remote_marker_required": { "const": true },
    "remote_marker_value": { "const": "staging" },
    "production_compose_service_count": { "const": 5 },
    "compose_services": {
      "type": "array",
      "prefixItems": [
        { "const": "postgres" },
        { "const": "redis" },
        { "const": "migrate" },
        { "const": "main-service-api" },
        { "const": "main-service-worker" }
      ],
      "items": false
    },
    "api_binding": { "const": "loopback-only" },
    "api_host_port": {
      "type": "integer",
      "minimum": 1024,
      "maximum": 65535,
      "not": { "enum": [80, 443] }
    },
    "public_database_port_allowed": { "const": false },
    "public_redis_port_allowed": { "const": false },
    "public_worker_port_allowed": { "const": false },
    "persistent_postgresql_volume_required": { "const": true },
    "persistent_redis_volume_required": { "const": true },
    "off_host_postgresql_backup_required_before_rollout": { "const": true },
    "resource_limits": { "const": "site-specific-after-benchmark" },
    "capacity_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpu_ram_not_invented",
        "measurements_required_before_sizing",
        "formula",
        "single_host_failure_domain",
        "ha_claimed"
      ],
      "properties": {
        "cpu_ram_not_invented": { "const": true },
        "measurements_required_before_sizing": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "formula": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "single_host_failure_domain": { "const": true },
        "ha_claimed": { "const": false }
      }
    },
    "filesystem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "remote_environment_marker_path",
        "remote_base_dir",
        "release_layout_required",
        "operator_owns_directory_creation",
        "world_writable_paths_allowed"
      ],
      "properties": {
        "remote_environment_marker_path": {
          "type": "string",
          "pattern": "^/"
        },
        "remote_base_dir": {
          "type": "string",
          "pattern": "^/(opt|srv|var/opt)/habersoft/.+staging.*$"
        },
        "release_layout_required": { "const": true },
        "operator_owns_directory_creation": { "const": true },
        "world_writable_paths_allowed": { "const": false }
      }
    },
    "edge_conditions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_hostname_allowed",
        "production_ip_allowed",
        "public_database_or_redis_allowed",
        "dns_tls_cyberpanel_live_change_performed",
        "external_registry_publish_performed"
      ],
      "properties": {
        "production_hostname_allowed": { "const": false },
        "production_ip_allowed": { "const": false },
        "public_database_or_redis_allowed": { "const": false },
        "dns_tls_cyberpanel_live_change_performed": { "const": false },
        "external_registry_publish_performed": { "const": false }
      }
    },
    "remote_preflight_required": { "const": true },
    "remote_mutation_performed": { "const": false },
    "remote_deployment_performed": { "const": false }
  }
}
